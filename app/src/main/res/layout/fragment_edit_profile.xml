<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/myColorSurface"
    tools:context=".ui.profile_edit.EditProfileFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/tool_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="@dimen/_42sdp"
            android:layout_height="@dimen/_42sdp"
            android:background="@color/transparent"
            android:src="@drawable/btn_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/myColorOnSurface" />


        <TextView
            android:id="@+id/btn_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_12sdp"
            android:fontFamily="@font/inter"
            android:text="@string/text_save"
            android:textColor="@color/color_primary_045DCC"
            android:textSize="@dimen/_14ssp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/_32sdp"
        app:layout_constraintBottom_toTopOf="@id/btn_remove_profile"
        app:layout_constraintTop_toBottomOf="@id/tool_bar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guide_start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.04" />


            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guide_end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.96" />

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/_1sdp"
                android:background="@color/color_primary_037EB9"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/title_profile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_36sdp"
                android:fontFamily="@font/inter"
                android:text="@string/text_edit_profiles"
                android:textColor="?attr/textTitle"
                android:textSize="@dimen/_20ssp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/avatar"
                android:layout_width="@dimen/_110sdp"
                android:layout_height="@dimen/_110sdp"
                android:layout_marginTop="@dimen/_8sdp"
                android:src="@drawable/avatar_default"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/title_profile" />

            <ImageView
                android:id="@+id/btn_edit_avatar"
                android:layout_width="@dimen/_32sdp"
                android:layout_height="@dimen/_32sdp"
                android:background="@drawable/bg_circle_button"
                android:padding="@dimen/_6sdp"
                android:src="@drawable/ic_edit"
                app:layout_constraintBottom_toBottomOf="@id/avatar"
                app:layout_constraintEnd_toEndOf="@id/avatar"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/title_profile_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_12sdp"
                android:fontFamily="@font/inter"
                android:text="@string/text_profile_name"
                android:textColor="?attr/myColorOnSurface"
                android:textSize="@dimen/_16ssp"
                app:layout_constraintStart_toStartOf="@id/guide_start"
                app:layout_constraintTop_toBottomOf="@id/avatar" />


            <TextView
                android:id="@+id/title_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_12sdp"
                android:fontFamily="@font/inter"
                android:text="@string/text_username"
                android:textColor="?attr/myColorOnSurface"
                android:textSize="@dimen/_16ssp"
                app:layout_constraintStart_toStartOf="@id/guide_start"
                app:layout_constraintTop_toBottomOf="@id/layour_profile_name" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layour_profile_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textColorHint="?attr/textHint"
                app:boxBackgroundColor="?attr/colorBgBox"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="@dimen/_12sdp"
                app:boxCornerRadiusBottomStart="@dimen/_12sdp"
                app:boxCornerRadiusTopEnd="@dimen/_12sdp"
                app:boxCornerRadiusTopStart="@dimen/_10sdp"
                app:boxStrokeColor="@color/textinput_stroke_color"
                app:boxStrokeWidth="@dimen/_1sdp"
                app:boxStrokeWidthFocused="@dimen/_2sdp"
                app:hintTextColor="@color/hint_color"
                app:layout_constraintEnd_toEndOf="@id/guide_end"
                app:layout_constraintStart_toStartOf="@id/guide_start"
                app:layout_constraintTop_toBottomOf="@id/title_profile_name">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/profile_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:inputType="text"
                    android:textColor="?attr/myColorOnSurface"
                    android:textSize="@dimen/_14ssp" />

            </com.google.android.material.textfield.TextInputLayout>


            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_username"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textColorHint="?attr/textHint"
                app:boxBackgroundColor="?attr/colorBgBox"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="@dimen/_12sdp"
                app:boxCornerRadiusBottomStart="@dimen/_12sdp"
                app:boxCornerRadiusTopEnd="@dimen/_12sdp"
                app:boxCornerRadiusTopStart="@dimen/_10sdp"
                app:boxStrokeColor="@color/textinput_stroke_color"
                app:boxStrokeWidth="@dimen/_1sdp"
                app:boxStrokeWidthFocused="@dimen/_2sdp"
                app:hintTextColor="@color/hint_color"
                app:layout_constraintEnd_toEndOf="@id/guide_end"
                app:layout_constraintStart_toStartOf="@id/guide_start"
                app:layout_constraintTop_toBottomOf="@id/title_username">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/username"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:inputType="text"
                    android:enabled="false"
                    android:textColor="?attr/myColorOnSurface"
                    android:textSize="@dimen/_14ssp" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/title_password"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_8sdp"
                android:fontFamily="@font/inter"
                android:text="@string/text_password"
                android:textColor="?attr/myColorOnSurface"
                android:textSize="@dimen/_16ssp"
                app:layout_constraintStart_toStartOf="@id/guide_start"
                app:layout_constraintTop_toBottomOf="@id/layout_username" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_password"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textColorHint="?attr/textHint"
                app:boxBackgroundColor="?attr/colorBgBox"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="@dimen/_12sdp"
                app:boxCornerRadiusBottomStart="@dimen/_12sdp"
                app:boxCornerRadiusTopEnd="@dimen/_12sdp"
                app:boxCornerRadiusTopStart="@dimen/_10sdp"
                app:boxStrokeColor="@color/textinput_stroke_color"
                app:boxStrokeWidth="@dimen/_1sdp"
                app:boxStrokeWidthFocused="@dimen/_2sdp"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/text_color_045DCC"
                app:hintTextColor="@color/hint_color"
                app:layout_constraintEnd_toEndOf="@id/guide_end"
                app:layout_constraintStart_toStartOf="@id/guide_start"
                app:layout_constraintTop_toBottomOf="@id/title_password">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:enabled="false"
                    android:fontFamily="@font/inter"
                    android:inputType="textPassword"
                    android:textColor="?attr/myColorOnSurface"
                    android:textSize="@dimen/_14ssp" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/title_url"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_8sdp"
                android:fontFamily="@font/inter"
                android:text="@string/text_url_server"
                android:textColor="?attr/myColorOnSurface"
                android:textSize="@dimen/_16ssp"
                app:layout_constraintStart_toStartOf="@id/guide_start"
                app:layout_constraintTop_toBottomOf="@id/layout_password" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_url_server"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textColorHint="?attr/textHint"
                app:boxBackgroundColor="?attr/colorBgBox"
                app:boxBackgroundMode="outline"
                app:boxCornerRadiusBottomEnd="@dimen/_12sdp"
                app:boxCornerRadiusBottomStart="@dimen/_12sdp"
                app:boxCornerRadiusTopEnd="@dimen/_12sdp"
                app:boxCornerRadiusTopStart="@dimen/_10sdp"
                app:boxStrokeColor="@color/textinput_stroke_color"
                app:boxStrokeWidth="@dimen/_1sdp"
                app:boxStrokeWidthFocused="@dimen/_2sdp"
                app:endIconDrawable="@drawable/ic_copy"
                app:endIconMode="custom"
                app:endIconTint="@color/color_primary_045DCC"
                app:hintTextColor="@color/hint_color"
                app:layout_constraintEnd_toEndOf="@id/guide_end"
                app:layout_constraintStart_toStartOf="@id/guide_start"
                app:layout_constraintTop_toBottomOf="@id/title_url">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/url_server"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:enabled="false"
                    android:inputType="textUri"
                    android:textColor="?attr/myColorOnSurface"
                    android:textSize="@dimen/_16ssp" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/title_passcode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_8sdp"
                android:fontFamily="@font/inter"
                android:text="@string/text_passcode_optional"
                android:textColor="?attr/myColorOnSurface"
                android:textSize="@dimen/_16ssp"
                app:layout_constraintStart_toStartOf="@id/guide_start"
                app:layout_constraintTop_toBottomOf="@id/layout_url_server" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btn_passcode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_6sdp"
                android:background="@drawable/box_bg"
                android:clipToPadding="false"
                android:padding="@dimen/_8sdp"
                android:paddingTop="@dimen/_4sdp"
                android:paddingBottom="@dimen/_4sdp"
                app:layout_constraintEnd_toEndOf="@id/guide_end"
                app:layout_constraintStart_toStartOf="@id/guide_start"
                app:layout_constraintTop_toBottomOf="@id/title_passcode">

                <ImageView
                    android:id="@+id/ic_upload_m3u"
                    android:layout_width="@dimen/_24sdp"
                    android:layout_height="@dimen/_24sdp"
                    android:src="@drawable/ic_passcode"
                    app:layout_constraintBottom_toBottomOf="@id/line"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/title_3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_6sdp"
                    android:fontFamily="@font/inter"
                    android:text="@string/text_set_passcode_security"
                    android:textColor="?attr/myColorOnSurface"
                    android:textSize="@dimen/_12ssp"
                    app:layout_constraintStart_toEndOf="@id/ic_upload_m3u"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/title_4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_6sdp"
                    android:fontFamily="@font/inter"
                    android:text="@string/text_make_our_playlist_private"
                    android:textColor="?attr/textHint"
                    android:textSize="@dimen/_10ssp"
                    app:layout_constraintStart_toEndOf="@id/ic_upload_m3u"
                    app:layout_constraintTop_toBottomOf="@id/title_3" />

                <TextView
                    android:layout_width="@dimen/_235sdp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_6sdp"
                    android:fontFamily="@font/inter"
                    android:text="@string/text_to_watch_many_tv_channels"
                    android:textColor="#4A5565"
                    android:textSize="@dimen/_12ssp"
                    android:visibility="gone"
                    app:layout_constraintStart_toEndOf="@id/ic_upload_m3u"
                    app:layout_constraintTop_toBottomOf="@id/title_3" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/btn_toggle_music"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toTopOf="@id/line"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.9"
                    app:layout_constraintStart_toEndOf="@id/title_3"
                    app:layout_constraintTop_toTopOf="parent"
                    app:showText="false"
                    app:thumbIcon="@drawable/thumb_toggle"
                    app:thumbIconTint="@color/white"
                    app:thumbTint="@color/white"
                    app:trackTint="@color/track_switch_color"
                    tools:checked="false" />

                <View
                    android:id="@+id/line"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_1sdp"
                    android:layout_marginTop="@dimen/_4sdp"
                    android:background="?attr/textHint"
                    app:layout_constraintTop_toBottomOf="@id/title_4" />

                <TextView
                    android:id="@+id/btn_change_passcode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_6sdp"
                    android:fontFamily="@font/inter"
                    android:text="@string/text_change_your_passcode"
                    android:textColor="@color/color_primary_045DCC"
                    android:textSize="@dimen/_14ssp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/line" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/btn_remove_profile"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:background="?attr/colorBgBox"
        app:layout_constraintDimensionRatio="360:65"
        app:layout_constraintBottom_toBottomOf="parent"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="@dimen/_24sdp"
            android:layout_height="@dimen/_26sdp"
            android:src="@drawable/ic_delete"
            />

        <TextView
            android:id="@+id/text_remove"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_6sdp"
            android:fontFamily="@font/inter"
            android:text="@string/text_remove_profile"
            android:textColor="#DB2F2F"
            android:textSize="@dimen/_14ssp"
            />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>