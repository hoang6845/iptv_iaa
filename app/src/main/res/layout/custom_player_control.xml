<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/controlsOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="16:9"
        android:background="#30000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            app:layout_constraintTop_toTopOf="parent"
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

<!--            <ImageButton-->
<!--                android:id="@+id/btnBack"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:background="@color/transparent"-->
<!--                android:contentDescription="Back"-->
<!--                android:src="@drawable/btn_back"-->
<!--                app:tint="@color/white" />-->

<!--            <TextView-->
<!--                android:id="@+id/tvTitle"-->
<!--                android:layout_width="0dp"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:layout_marginHorizontal="12dp"-->
<!--                android:layout_weight="1"-->
<!--                android:ellipsize="end"-->
<!--                android:maxLines="1"-->
<!--                tools:text="Movie Titleasdasdasdasdasdasdasdasd"-->
<!--                android:textColor="#FFFFFF"-->
<!--                android:textSize="@dimen/_12ssp"-->
<!--                android:textStyle="bold" />-->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="@dimen/_32sdp"
                android:layout_height="@dimen/_32sdp"
                android:background="@color/transparent"
                android:src="@drawable/btn_back"
                android:visibility="gone"
                app:tint="@color/white" />
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginHorizontal="12dp"
                android:layout_weight="1"
             />

            <ImageButton
                android:id="@+id/btn_favourite"
                android:layout_width="@dimen/_28sdp"
                android:visibility="gone"
                android:layout_height="@dimen/_28sdp"
                android:background="@color/transparent"
                android:layout_marginEnd="@dimen/_4sdp"
                android:contentDescription="Favourite"
                android:src="@drawable/favourited"
                />

            <ImageButton
                android:id="@+id/btn_cast"
                android:layout_width="@dimen/_32sdp"
                android:layout_height="@dimen/_32sdp"
                android:background="@drawable/bg_circle_button_black"
                android:contentDescription="Sleep Timer"
                android:src="@drawable/ic_cast"
                app:tint="@color/white" />

        </LinearLayout>


        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/progress"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.12"
            app:lottie_autoPlay="false"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/load" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="@dimen/_90sdp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:ellipsize="end"
            android:layout_gravity="bottom"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="@dimen/_12sdp"
            android:maxLines="1"
            app:layout_constraintBottom_toTopOf="@id/bottom_control"
            tools:text="Movie Titleasdasdasadasdadasdsdasdasdasdasdasd"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/_12ssp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/ic_live"
            android:layout_width="@dimen/_28sdp"
            android:layout_height="@dimen/_28sdp"
            android:background="@color/transparent"
            android:layout_marginEnd="@dimen/_4sdp"
            android:contentDescription="ic_live"
            android:src="@drawable/ic_live"
            app:layout_constraintTop_toTopOf="@id/tvTitle"
            app:layout_constraintBottom_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toEndOf="@id/tvTitle"
            />

        <LinearLayout
            android:id="@+id/bottom_control"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp">

                <SeekBar
                    android:id="@+id/seekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:layout_weight="1"
                    android:max="1000"
                    android:progressTint="#E53935"
                    android:thumbTint="#E53935" />

                <ImageButton
                    android:id="@+id/btnPicture"
                    android:layout_width="@dimen/_32sdp"
                    android:layout_height="@dimen/_32sdp"
                    android:layout_marginStart="8dp"
                    android:background="@color/transparent"
                    android:contentDescription="picture in picture"
                    android:src="@drawable/ic_popup_play"
                    app:tint="@color/white" />

                <ImageButton
                    android:id="@+id/btnFullscreen"
                    android:layout_width="@dimen/_32sdp"
                    android:layout_height="@dimen/_32sdp"
                    android:layout_marginStart="8dp"
                    android:background="@color/transparent"
                    android:contentDescription="Fullscreen"
                    android:src="@drawable/ic_fullscreen"
                    app:tint="@color/white" />
            </LinearLayout>


        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.constraintlayout.widget.ConstraintLayout>