<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="?attr/myColorSurface"
    tools:context=".ui.profile.ProfileFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/tool_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageButton
            app:layout_constraintTop_toTopOf="parent"
            android:id="@+id/btnBack"
            android:layout_width="@dimen/_42sdp"
            android:layout_height="@dimen/_42sdp"
            android:background="@color/transparent"
            app:layout_constraintStart_toStartOf="parent"
            android:src="@drawable/btn_back"
            app:tint="?attr/myColorOnSurface"
            />


        <TextView
            android:id="@+id/switch_account"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:text="@string/text_switch_account"
            android:textColor="?attr/myColorOnSurface"
            android:textSize="@dimen/_14ssp"
            android:layout_marginEnd="@dimen/_12sdp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/title_profile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter"
        android:layout_marginTop="@dimen/_36sdp"
        android:text="@string/text_profile"
        android:textColor="?attr/textTitle"
        android:textStyle="bold"
        android:textSize="@dimen/_20ssp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tool_bar" />

    <ImageView
        android:id="@+id/avatar"
        android:layout_width="@dimen/_110sdp"
        android:layout_height="@dimen/_110sdp"
        app:layout_constraintTop_toBottomOf="@id/title_profile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:src="@drawable/avatar_default"
        android:layout_marginTop="@dimen/_8sdp" />

    <TextView
        android:id="@+id/name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter"
        android:layout_marginTop="@dimen/_4sdp"
        tools:text="asdasd"
        android:textColor="?attr/myColorOnSurface"
        android:textSize="@dimen/_14ssp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/avatar" />

    <TextView
        android:id="@+id/btn_edit_profile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/text_edit_profiles"
        android:textColor="#889DB8"
        android:background="@drawable/shape_btn_edit"
        android:paddingVertical="@dimen/_10sdp"
        android:paddingHorizontal="@dimen/_17sdp"
        android:textSize="@dimen/_14ssp"
        app:layout_constraintTop_toBottomOf="@id/name"
        android:layout_marginTop="@dimen/_6sdp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    
    <LinearLayout
        android:id="@+id/btn_watchlist"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@drawable/box_bg_profile"
        app:layout_constraintDimensionRatio="332:48"
        android:layout_marginTop="@dimen/_16sdp"
        app:layout_constraintTop_toBottomOf="@id/btn_edit_profile"
        android:layout_marginHorizontal="@dimen/_12sdp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/_14ssp"
            android:text="@string/text_watchlist"
            android:layout_gravity="center|start"
            android:textColor="?attr/myColorOnSurface"
            android:fontFamily="@font/inter"
            android:layout_marginStart="@dimen/_12sdp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/transparent"
            android:layout_weight="1" />

        <ImageView
            android:layout_width="@dimen/_24sdp"
            android:layout_height="@dimen/_24sdp"
            android:src="@drawable/ic_arrow_right"
            android:layout_marginEnd="@dimen/_10sdp"
            app:tint="?attr/myColorOnSurface"
            android:layout_gravity="center|end" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_setting"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@drawable/box_bg_profile"
        app:layout_constraintDimensionRatio="332:48"
        android:layout_marginTop="@dimen/_8sdp"
        app:layout_constraintTop_toBottomOf="@id/btn_watchlist"
        android:layout_marginHorizontal="@dimen/_12sdp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/_14ssp"
            android:text="@string/text_general_settings"
            android:layout_gravity="center|start"
            android:textColor="?attr/myColorOnSurface"
            android:fontFamily="@font/inter"
            android:layout_marginStart="@dimen/_12sdp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/transparent"
            android:layout_weight="1" />

        <ImageView
            android:layout_width="@dimen/_24sdp"
            android:layout_height="@dimen/_24sdp"
            android:src="@drawable/ic_arrow_right"
            android:layout_marginEnd="@dimen/_10sdp"
            app:tint="?attr/myColorOnSurface"
            android:layout_gravity="center|end" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_account"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@drawable/box_bg_profile"
        app:layout_constraintDimensionRatio="332:48"
        android:layout_marginTop="@dimen/_8sdp"
        app:layout_constraintTop_toBottomOf="@id/btn_setting"
        android:layout_marginHorizontal="@dimen/_12sdp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/_14ssp"
            android:text="@string/text_account"
            android:layout_gravity="center|start"
            android:textColor="?attr/myColorOnSurface"
            android:fontFamily="@font/inter"
            android:layout_marginStart="@dimen/_12sdp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/transparent"
            android:layout_weight="1" />

        <ImageView
            android:layout_width="@dimen/_24sdp"
            android:layout_height="@dimen/_24sdp"
            android:src="@drawable/ic_arrow_right"
            android:layout_marginEnd="@dimen/_10sdp"
            app:tint="?attr/myColorOnSurface"
            android:layout_gravity="center|end" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>