<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TabTextStyle">
        <item name="android:textSize">@dimen/_14ssp</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="MyMaterialSwitch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="thumbTint">@color/white</item>
        <item name="trackTint">@color/track_switch_color</item>
    </style>

    <style name="SleepTimerOption">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">@dimen/_14ssp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:fontFamily">@font/inter</item>

    </style>
    <style name="ShapeAppearance.MyApp.SmallComponent" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">13dp</item>
    </style>
    <style name="NumpadButton">
        <item name="android:layout_width">68dp</item>
        <item name="android:layout_height">68dp</item>
        <item name="android:layout_margin">10dp</item>
        <item name="android:background">@drawable/bg_num_pad_button</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/color_primary_045DCC</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:gravity">center</item>
        <item name="android:elevation">2dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="ShapeAppearance.Carousel" parent="">
        <item name="cornerSize">@dimen/_12sdp</item>
        <item name="cornerFamily">rounded</item>
    </style>

    <style name="RightPanelDialog" parent="Theme.AppCompat.Dialog">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowAnimationStyle">@style/RightPanelAnimation</item>
    </style>

    <style name="RightPanelAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_in_right</item>
        <item name="android:windowExitAnimation">@anim/slide_out_right</item>
    </style>
</resources>