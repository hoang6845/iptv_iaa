<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="?attr/myColorSurface" />
            <stroke android:width="1.5dp" android:color="@color/color_primary_045DCC" />
            <size android:width="68dp" android:height="68dp" />
        </shape>
    </item>

    <!-- Default state -->
    <item>
        <shape android:shape="oval">
            <solid android:color="?attr/myColorSurface" />
            <stroke android:width="1dp" android:color="@color/color_primary_045DCC" />
            <size android:width="68dp" android:height="68dp" />
            <!-- Soft shadow via layer-list below if needed -->
        </shape>
    </item>

</selector>