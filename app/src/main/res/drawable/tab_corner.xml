<?xml version="1.0" encoding="utf-8"?><!-- res/drawable/spinner_background.xml -->
<!-- Rounded border background for the Spinner (closed state) -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <gradient
        android:startColor="@color/color_primary_037EB9"
        android:endColor="@color/color_primary_045DCC" />
    <stroke
        android:width="1dp"
        android:color="?attr/colorPrimary" />

    <corners android:radius="@dimen/_24sdp" />

</shape>