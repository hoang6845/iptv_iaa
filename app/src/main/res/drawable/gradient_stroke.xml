<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Lớp dưới: gradient → đây chính là "viền" -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="@color/color_primary_037EB9"
                android:endColor="@color/color_primary_045DCC" />
            <corners android:radius="@dimen/_7sdp" />
        </shape>
    </item>

    <!-- Lớp trên: background solid, inset vào trong → tạo ra phần viền lộ ra -->
    <item
        android:bottom="1.5dp"
        android:left="1.5dp"
        android:right="1.5dp"
        android:top="1.5dp">
        <shape android:shape="rectangle">
            <solid android:color="?attr/myColorSurface" />
            <corners android:radius="@dimen/_7sdp" /> <!-- radius - stroke width -->
        </shape>
    </item>

</layer-list>