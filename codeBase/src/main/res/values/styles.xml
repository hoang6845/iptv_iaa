<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="NavItemStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginHorizontal">6dp</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingVertical">@dimen/_2sdp</item>
        <item name="android:paddingHorizontal">@dimen/_8sdp</item>
        <item name="android:background">@drawable/bg_nav_unselected</item>
    </style>
    <style name="CircleImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
    <style name="NoIndicator">
        <item name="android:color">@android:color/transparent</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.Full</item>
        <item name="android:height">0dp</item>
        <item name="android:width">0dp</item>
    </style>
</resources>